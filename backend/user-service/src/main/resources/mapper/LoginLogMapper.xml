<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.userservice.mapper.LoginLogMapper">

    <select id="selectPageWithUser" resultType="com.example.userservice.entity.LoginLog">
        SELECT l.*, u.username, u.full_name as fullName
        FROM login_logs l
        LEFT JOIN users u ON l.user_id = u.id
        ORDER BY l.login_time DESC
    </select>

</mapper>
